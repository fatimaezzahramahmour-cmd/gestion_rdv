# Copier vers .env (ne jamais committer .env)
# Sécurité production

DJANGO_SECRET_KEY=changez-moi-longue-chaine-aleatoire
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=votredomaine.com,www.votredomaine.com

# Obligatoire si HTTPS + domaine (séparez par des virgules)
CSRF_TRUSTED_ORIGINS=https://votredomaine.com,https://www.votredomaine.com

# MySQL (ne pas laisser le mot de passe vide en prod)
MYSQL_DATABASE=gestion_rdv
MYSQL_USER=gestion_rdv
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Redirection HTTP→HTTPS (0 si test local sans SSL)
DJANGO_SECURE_SSL_REDIRECT=1
